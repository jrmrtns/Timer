<Window x:Class="Overlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" 
        Width="240"
        Height="240"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded">

    <Border x:Name="RootBorder"
            Background="#80333333"
            BorderThickness="0"
            CornerRadius="20"
            Padding="16"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Direction="270" 
                            ShadowDepth="8" 
                            BlurRadius="20" 
                            Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close Button rechts oben - modernisiert -->
            <Button Grid.Row="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="32"
                    Height="32"
                    Margin="0,-6,-6,0"
                    Click="Close_Click"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ButtonBackground"
                                    Fill="#33FF3366"
                                    Stroke="#88FF3366"
                                    StrokeThickness="2">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FFFF3366" 
                                                    BlurRadius="8" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="CloseIcon"
                                          Data="M6,6 L18,18 M18,6 L6,18"
                                          Stroke="#FFFFFF"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Fill" Value="#88FF3366"/>
                                <Setter TargetName="ButtonBackground" Property="Stroke" Value="#FFFFFF"/>
                                <Setter TargetName="CloseIcon" Property="Stroke" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Fill" Value="#DDFF3366"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Theme Button links oben -->
            <Button Grid.Row="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="32"
                    Height="32"
                    Margin="-6,-6,0,0"
                    Click="Theme_Click"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ThemeButtonBackground"
                                    Fill="#33FFFFFF"
                                    Stroke="#88FFFFFF"
                                    StrokeThickness="2">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FFFFFFFF" 
                                                    BlurRadius="8" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="PaletteIcon"
                                          Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C13.1,22 14,21.1 14,20 C14,19.48 13.8,19.01 13.48,18.66 C13.17,18.32 13,17.88 13,17.4 C13,16.28 13.9,15.4 15,15.4 L16.7,15.4 C19.39,15.4 21.6,13.19 21.6,10.5 C21.6,5.8 17.28,2 12,2 Z M6.5,12 C5.67,12 5,11.33 5,10.5 C5,9.67 5.67,9 6.5,9 C7.33,9 8,9.67 8,10.5 C8,11.33 7.33,12 6.5,12 Z M9.5,8 C8.67,8 8,7.33 8,6.5 C8,5.67 8.67,5 9.5,5 C10.33,5 11,5.67 11,6.5 C11,7.33 10.33,8 9.5,8 Z M14.5,8 C13.67,8 13,7.33 13,6.5 C13,5.67 13.67,5 14.5,5 C15.33,5 16,5.67 16,6.5 C16,7.33 15.33,8 14.5,8 Z M17.5,12 C16.67,12 16,11.33 16,10.5 C16,9.67 16.67,9 17.5,9 C18.33,9 19,9.67 19,10.5 C19,11.33 18.33,12 17.5,12 Z"
                                          Fill="#FFFFFF"
                                          Stretch="Uniform"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThemeButtonBackground" Property="Fill" Value="#88FFFFFF"/>
                                <Setter TargetName="ThemeButtonBackground" Property="Stroke" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ThemeButtonBackground" Property="Fill" Value="#DDFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.ContextMenu>
                    <ContextMenu x:Name="ThemeContextMenu"
                                 Background="#E5000000"
                                 BorderThickness="1"
                                 Padding="4">
                        <ContextMenu.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
                                <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="1"/>
                            </LinearGradientBrush>
                        </ContextMenu.BorderBrush>
                        <ContextMenu.Resources>
                            <Style TargetType="MenuItem">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="{DynamicResource HighlightCyan}" Offset="0"/>
                                                    <GradientStop Color="{DynamicResource HighlightPurple}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ContextMenu.Resources>
                        <MenuItem Header="Cyan-Purple" Click="SetTheme_Click" Tag="CyanPurple"/>
                        <MenuItem Header="Red-Orange" Click="SetTheme_Click" Tag="RedOrange"/>
                        <MenuItem Header="Green-Lime" Click="SetTheme_Click" Tag="GreenLime"/>
                        <MenuItem Header="Pink-Magenta" Click="SetTheme_Click" Tag="PinkMagenta"/>
                        <MenuItem Header="Gold-Amber" Click="SetTheme_Click" Tag="GoldAmber"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <!-- Pie Chart Progress -->
            <Grid Grid.Row="0"
                  Width="140"
                  Height="140"
                  Margin="0,5,0,0"
                  HorizontalAlignment="Center">

                <!-- Background Circle -->
                <Ellipse Width="140" Height="140">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#33000000" Offset="0"/>
                            <GradientStop Color="#11000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="{DynamicResource PrimaryCyan}" 
                                        BlurRadius="15" 
                                        ShadowDepth="0" 
                                        Opacity="0.3"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Background Ring -->
                <Ellipse Width="140"
                         Height="140"
                         StrokeThickness="3"
                         Stroke="#33FFFFFF"/>

                <!-- Progress Pie Chart -->
                <Canvas x:Name="PieCanvas" Width="140" Height="140">
                    <Path x:Name="ProgressPie"
                          StrokeThickness="0">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
                                <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Fill>
                        <Path.Effect>
                            <DropShadowEffect Color="{DynamicResource PrimaryCyan}" 
                                            BlurRadius="10" 
                                            ShadowDepth="0" 
                                            Opacity="0.6"/>
                        </Path.Effect>
                    </Path>
                </Canvas>

                <!-- Center Circle -->
                <Ellipse Width="100"
                         Height="100"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#66000000" Offset="0"/>
                            <GradientStop Color="#33000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Time Remaining Text -->
                <TextBlock x:Name="CenterTimeText"
                           Text="10:00"
                           FontSize="32"
                           FontWeight="Bold"
                           Cursor="Hand"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="CenterTimeText_MouseLeftButtonDown">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
                            <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{DynamicResource PrimaryCyan}" 
                                        BlurRadius="8" 
                                        ShadowDepth="0" 
                                        Opacity="0.6"/>
                    </TextBlock.Effect>
                    <TextBlock.ContextMenu>
                        <ContextMenu x:Name="TimeContextMenu"
                                     Background="#E5000000"
                                     BorderThickness="1"
                                     Padding="4"
                                     StaysOpen="False"
                                     Opened="TimeContextMenu_Opened">
                            <ContextMenu.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="1"/>
                                </LinearGradientBrush>
                            </ContextMenu.BorderBrush>
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{DynamicResource HighlightCyan}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource HighlightPurple}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ContextMenu.Resources>
                            <MenuItem Header="5 Minuten" Click="SetTime_Click" Tag="5"/>
                            <MenuItem Header="10 Minuten" Click="SetTime_Click" Tag="10"/>
                            <MenuItem Header="15 Minuten" Click="SetTime_Click" Tag="15"/>
                            <MenuItem Header="20 Minuten" Click="SetTime_Click" Tag="20"/>
                            <MenuItem Header="30 Minuten" Click="SetTime_Click" Tag="30"/>
                            <MenuItem Header="45 Minuten" Click="SetTime_Click" Tag="45"/>
                            <MenuItem Header="60 Minuten" Click="SetTime_Click" Tag="60"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
            </Grid>

            <!-- Moderner Start/Pause Button -->
            <Button x:Name="StartPauseButton"
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    Margin="0,18,0,0"
                    Width="100"
                    Height="36"
                    Click="StartPause_Click"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="20"
                                BorderThickness="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource BackgroundDarkCyan}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource BackgroundDarkPurple}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect x:Name="ButtonShadow"
                                                Color="{DynamicResource PrimaryCyan}" 
                                                BlurRadius="10" 
                                                ShadowDepth="0" 
                                                Opacity="0.4"/>
                            </Border.Effect>
                            <TextBlock x:Name="ButtonText"
                                       Text="Start"
                                       Foreground="#FFFFFF"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource HoverCyan}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource HoverPurple}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource PressedCyan}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource PressedPurple}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>

