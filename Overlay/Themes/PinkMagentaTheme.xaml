<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Farbdefinitionen: Pink-Magenta -->
    <Color x:Key="PrimaryCyan">#FFFF1493</Color>
    <Color x:Key="PrimaryCyanDark">#FFCC0066</Color>
    <Color x:Key="PrimaryPurple">#FFFF00FF</Color>
    <Color x:Key="PrimaryPurpleDark">#FFCC00CC</Color>

    <Color x:Key="AccentCyan">#88FF1493</Color>
    <Color x:Key="AccentPurple">#88FF00FF</Color>

    <Color x:Key="BackgroundDarkCyan">#88440033</Color>
    <Color x:Key="BackgroundDarkPurple">#88330044</Color>
    <Color x:Key="HoverCyan">#AA550044</Color>
    <Color x:Key="HoverPurple">#AA440055</Color>
    <Color x:Key="PressedCyan">#CCAA0066</Color>
    <Color x:Key="PressedPurple">#CC8800AA</Color>

    <Color x:Key="HighlightCyan">#66FF1493</Color>
    <Color x:Key="HighlightPurple">#66FF00FF</Color>

    <!-- SolidColorBrush für Fill-Eigenschaften -->
    <SolidColorBrush x:Key="PrimaryCyanBrush" Color="{DynamicResource PrimaryCyan}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{DynamicResource AccentCyan}"/>

    <!-- Moderner Gradient für Buttons -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryCyanDark}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryPurpleDark}" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>

