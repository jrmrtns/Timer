<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Farbdefinitionen: Cyan-Purple -->
    <Color x:Key="PrimaryCyan">#FF00D9FF</Color>
    <Color x:Key="PrimaryCyanDark">#FF0099FF</Color>
    <Color x:Key="PrimaryPurple">#FF7B2FFF</Color>
    <Color x:Key="PrimaryPurpleDark">#FF5B2FFF</Color>

    <Color x:Key="AccentCyan">#8800D9FF</Color>
    <Color x:Key="AccentPurple">#887B2FFF</Color>

    <Color x:Key="BackgroundDarkCyan">#88004488</Color>
    <Color x:Key="BackgroundDarkPurple">#88003366</Color>
    <Color x:Key="HoverCyan">#AA005599</Color>
    <Color x:Key="HoverPurple">#AA004477</Color>
    <Color x:Key="PressedCyan">#CC0066AA</Color>
    <Color x:Key="PressedPurple">#CC005588</Color>

    <Color x:Key="HighlightCyan">#6600D9FF</Color>
    <Color x:Key="HighlightPurple">#667B2FFF</Color>

    <!-- SolidColorBrush für Fill-Eigenschaften -->
    <SolidColorBrush x:Key="PrimaryCyanBrush" Color="{DynamicResource PrimaryCyan}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{DynamicResource AccentCyan}"/>

    <!-- Moderner Gradient für Buttons -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryCyanDark}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryPurpleDark}" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>

