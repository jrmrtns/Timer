<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Farbdefinitionen: Blue-Indigo -->
    <Color x:Key="PrimaryCyan">#FF0088FF</Color>
    <Color x:Key="PrimaryCyanDark">#FF0055CC</Color>
    <Color x:Key="PrimaryPurple">#FF4466FF</Color>
    <Color x:Key="PrimaryPurpleDark">#FF2244DD</Color>

    <Color x:Key="AccentCyan">#880088FF</Color>
    <Color x:Key="AccentPurple">#884466FF</Color>

    <Color x:Key="BackgroundDarkCyan">#88002244</Color>
    <Color x:Key="BackgroundDarkPurple">#88001133</Color>
    <Color x:Key="HoverCyan">#AA003355</Color>
    <Color x:Key="HoverPurple">#AA002244</Color>
    <Color x:Key="PressedCyan">#CC0066AA</Color>
    <Color x:Key="PressedPurple">#CC004488</Color>

    <Color x:Key="HighlightCyan">#660088FF</Color>
    <Color x:Key="HighlightPurple">#664466FF</Color>

    <!-- SolidColorBrush für Fill-Eigenschaften -->
    <SolidColorBrush x:Key="PrimaryCyanBrush" Color="{DynamicResource PrimaryCyan}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{DynamicResource AccentCyan}"/>

    <!-- Moderner Gradient für Buttons -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PrimaryCyan}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryCyanDark}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PrimaryPurple}" Offset="0"/>
        <GradientStop Color="{DynamicResource PrimaryPurpleDark}" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>

